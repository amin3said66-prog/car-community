# Security and Performance Configuration for npm

# Prevent installation of packages with unresolved peer dependencies
legacy-peer-deps=false

# Audit level - fail on moderate or higher vulnerabilities
audit-level=moderate

# Use HTTPS for all npm registries
registry=https://registry.npmjs.org/

# Verify SSL certificates
strict-ssl=true

# Limit concurrent network requests
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-retries=5

# Prefer offline cache
prefer-offline=true

